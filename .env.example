# Copy this file to ".env" and paste your real key after the "=".
#
#   cp .env.example .env      (macOS/Linux)
#   copy .env.example .env    (Windows cmd)
#
# Get a key at: https://console.anthropic.com/
#
# NOTE: The demo also runs WITHOUT a key. If this is blank or missing, the
# demo automatically falls back to "mock mode" — canned responses, zero cost.
# That makes it safe to run in a classroom where not everyone has a key.
ANTHROPIC_API_KEY=your_key_here
